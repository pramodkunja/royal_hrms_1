SECRET_KEY=your-very-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use PostgreSQL in production, NOT SQLite
# DATABASE_URL=postgresql://user:password@localhost:5432/hrms_db
DATABASE_URL=sqlite:///db.sqlite3
DB_CONN_MAX_AGE=60

# Redis — required for throttling and caching
REDIS_URL=redis://127.0.0.1:6379/1

# Email (use SMTP credentials)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Royal Staffing HRMS <your-email@gmail.com>

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
